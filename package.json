{
  "name": "flashcut",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "pnpm run build && wrangler dev",
    "test": "vitest run",
    "test:pwa": "pnpm run build && node scripts/pwa-smoke.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc -b",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@solidjs/router": "0.17.0-next.3",
    "@solidjs/web": "2.0.0-beta.17",
    "@tursodatabase/database-wasm": "^0.6.1",
    "dompurify": "^3.4.11",
    "invokers-polyfill": "^1.0.3",
    "marked": "^18.0.6",
    "solid-js": "2.0.0-beta.17",
    "temporal-polyfill": "^1.0.1",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@tursodatabase/database": "^0.6.1",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.110.0"
  }
}
